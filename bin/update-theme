#!/usr/bin/env bash
set -euo pipefail

GTK_THEME_DIR="$HOME/.themes/Orchis-theme"
GTK_REPO_URL="https://github.com/DragonRider01598/Orchis-theme.git"

ICON_THEME_DIR="$HOME/.local/share/icons/dreams-repo"
ICON_REPO_URL="https://codeberg.org/mi7i/dreams.git"

update_repo() {
    local dir="$1"
    local url="$2"
    local name="$3"

    if [[ ! -d "$dir" ]]; then
        echo "▶ $name not found, cloning repository..."
        mkdir -p "$(dirname "$dir")"
        git clone "$url" "$dir"
        return 0
    fi

    echo "▶ $name found. Checking for updates..."
    cd "$dir"
    git fetch
    
    local LOCAL=$(git rev-parse HEAD)
    local REMOTE=$(git rev-parse @{u})

    if [ "$LOCAL" = "$REMOTE" ]; then
        echo "✔ $name is already up to date."
        return 1
    fi

    echo "▶ Pulling latest $name changes..."
    git pull --ff-only
    return 0
}

if update_repo "$GTK_THEME_DIR" "$GTK_REPO_URL" "Orchis-theme"; then
    echo "▶ Reinstalling Orchis..."
    cd "$GTK_THEME_DIR"
    ./install.sh \
        -l \
        -c dark \
        -t teal \
        -i arch \
        -s standard \
        --tweaks macos primary submenu
fi

if update_repo "$ICON_THEME_DIR" "$ICON_REPO_URL" "Dreams-icons"; then
    echo "▶ Reinstalling Dreams Icons..."
    cd "$ICON_THEME_DIR"
    ./install.sh
fi

echo "✔ All themes updated successfully."
