#!/usr/bin/env bash
set -euo pipefail

if [[ $EUID -eq 0 ]]; then
  echo "Do not run this script as root."
  exit 1
fi

if command -v yay >/dev/null 2>&1; then
    echo "▶ Checking for updates..."

    LOCAL_VER=$(yay -Q yay-bin 2>/dev/null | awk '{print $2}' || yay -Q yay 2>/dev/null | awk '{print $2}' || echo "")
    REMOTE_VER=$(curl -s "https://aur.archlinux.org/cgit/aur.git/plain/PKGBUILD?h=yay-bin" | grep -Po 'pkgver=\K[^ ]+' || true)

    if [[ "$LOCAL_VER" == *"$REMOTE_VER"* ]]; then
        echo "✔ yay is up to date ($LOCAL_VER)."
        exit 0
    fi
    echo "▶ Update found: $LOCAL_VER -> $REMOTE_VER"
fi

TMPDIR="$(mktemp -d)"
trap 'rm -rf "$TMPDIR"' EXIT

echo "▶ Cloning yay-bin from AUR..."
cd "$TMPDIR"
git clone https://aur.archlinux.org/yay-bin.git
cd yay-bin

echo "▶ Building and installing..."
makepkg -si --noconfirm

echo "✔ yay-bin installed successfully."
